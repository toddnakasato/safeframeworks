---
/**
 * SafeDragDrop — Astro 5 drag-and-drop (generic / file / palette).
 * Renders via shared-mapping dragdrop builder (./dragdrop) — identical across
 * frameworks. Server-renders the shell; client script mounts the component.
 * Structure + data-* only.
 */
import type { ConfigBase, OnSafeEvent } from 'safecontracts';
interface Props { config: ConfigBase; onEvent?: OnSafeEvent; }
const { config } = Astro.props;
---

<div data-dragdrop-config={JSON.stringify(config)}></div>

<script>
  import { initSafeDragDrops } from "./dragdrop";
  initSafeDragDrops();
</script>
