---
/**
 * SafeTabs — Astro 5 tabbed panel navigation.
 * Renders via shared-mapping tabs builder (./tabs) — identical across
 * frameworks. Server-renders the shell; client script mounts the component.
 * Structure + data-* only.
 */
import type { ConfigBase, OnSafeEvent } from 'safecontracts';
interface Props { config: ConfigBase; onEvent?: OnSafeEvent; }
const { config } = Astro.props;
---

<div data-tabs-config={JSON.stringify(config)}></div>

<script>
  import { initSafeTabs } from "./tabs";
  initSafeTabs();
</script>
