---
/**
 * SafeFunnel — Astro 5 D3 funnel/conversion bars.
 * Renders via shared-mapping funnel builder (./funnel) — identical across
 * frameworks. Server-renders the shell; client script mounts the
 * component. Structure + data-* only.
 */
import type { ConfigBase, OnSafeEvent } from 'safecontracts';
interface Props { config: ConfigBase; onEvent?: OnSafeEvent; }
const { config } = Astro.props;
---

<div data-funnel-config={JSON.stringify(config)}></div>

<script>
  import { initSafeFunnels } from "./funnel";
  initSafeFunnels();
</script>
