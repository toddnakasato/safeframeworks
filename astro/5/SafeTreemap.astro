---
/**
 * SafeTreemap — Astro 5 D3 nested rectangles.
 * Renders via shared-mapping treemap builder (./treemap) — identical across
 * frameworks. Server-renders the shell; client script mounts the
 * component. Structure + data-* only.
 */
import type { ConfigBase, OnSafeEvent } from 'safecontracts';
interface Props { config: ConfigBase; onEvent?: OnSafeEvent; }
const { config } = Astro.props;
---

<div data-treemap-config={JSON.stringify(config)}></div>

<script>
  import { initSafeTreemaps } from "./treemap";
  initSafeTreemaps();
</script>
