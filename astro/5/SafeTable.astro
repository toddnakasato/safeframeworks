---
/**
 * SafeTable — Astro 5 table component.
 * Renders via shared-mapping table builder (./table) — identical across
 * frameworks. Server-renders the shell; client script mounts the table.
 * Structure + data-* only.
 */
import type { ConfigBase, OnSafeEvent } from 'safecontracts';
interface Props { config: ConfigBase; onEvent?: OnSafeEvent; }
const { config } = Astro.props;
---

<div data-table-config={JSON.stringify(config)}></div>

<script>
  import { initSafeTables } from "./table";
  initSafeTables();
</script>
