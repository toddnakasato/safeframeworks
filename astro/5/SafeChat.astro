---
/**
 * SafeChat — Astro 5 chat component.
 * Implements chat contract from safecontracts.
 * Outputs data-* attributes for intent. No hardcoded CSS.
 */
import type { ConfigBase, OnSafeEvent } from 'safecontracts';

interface Props {
  config: ConfigBase;
  onEvent?: OnSafeEvent;
}

const { config, onEvent } = Astro.props;
---

<div
  data-component="chat"
>
  {config.metadata.title && <div data-role="title">{config.metadata.title}</div>}
  <div data-role="messages">
    <slot />
  </div>
</div>
