---
/**
 * SafeColumns — Astro 5 12-column grid positioning.
 * Renders via shared-mapping columns builder (./columns) — identical across
 * frameworks. Server-renders the shell; client script mounts the
 * component. Structure + data-* only.
 */
import type { ConfigBase, OnSafeEvent } from 'safecontracts';
interface Props { config: ConfigBase; onEvent?: OnSafeEvent; }
const { config } = Astro.props;
---

<div data-columns-config={JSON.stringify(config)}></div>

<script>
  import { initSafeColumnsAll } from "./columns";
  initSafeColumnsAll();
</script>
