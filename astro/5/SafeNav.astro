---
/**
 * SafeNav — Astro 5 nav component.
 * Outputs data-* attributes for intent. No hardcoded CSS.
 */
import type { ConfigBase, OnSafeEvent } from 'safecontracts';
interface Props { config: ConfigBase; onEvent?: OnSafeEvent; }
const { config, onEvent } = Astro.props;
---

<div
  data-component="nav"
  data-nav-style={config.metadata.navStyle}
>
  {config.metadata.title && <div data-nav-header><div data-nav-logo>{config.metadata.title?.charAt(0)}</div><div data-nav-title>{config.metadata.title}</div></div>}
      <nav data-nav-main><slot /></nav>
</div>
