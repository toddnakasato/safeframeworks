---
/**
 * SafeNav — Astro 5 nav component.
 * navStyle "accordion" renders via shared-mapping nav builder (./nav) —
 * identical across frameworks (figma Shopfront design).
 * Server-renders the shell; a client script mounts the nav.
 */
import type { ConfigBase, OnSafeEvent } from 'safecontracts';
interface Props { config: ConfigBase; onEvent?: OnSafeEvent; }
const { config } = Astro.props;
---

<div data-nav-config={JSON.stringify(config)} style="height:100%"></div>

<script>
  import { initSafeNavs } from "./nav";
  initSafeNavs();
</script>
