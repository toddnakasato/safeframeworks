---
import { SAMPLES } from "../../../../../samples";
import SafeLayout from "../../../SafeLayout.astro";
import SafeColumns from "../../../SafeColumns.astro";
import SafeCard from "../../../SafeCard.astro";
import SafeButton from "../../../SafeButton.astro";
import SafeTable from "../../../SafeTable.astro";
import SafeTree from "../../../SafeTree.astro";
import SafeSheet from "../../../SafeSheet.astro";
import SafeChart from "../../../SafeChart.astro";
import SafeHeatmap from "../../../SafeHeatmap.astro";
import SafeGauge from "../../../SafeGauge.astro";
import SafeFunnel from "../../../SafeFunnel.astro";
import SafeSankey from "../../../SafeSankey.astro";
import SafeTreemap from "../../../SafeTreemap.astro";
import SafeTimeline from "../../../SafeTimeline.astro";
import SafeMap from "../../../SafeMap.astro";
import SafeCalendar from "../../../SafeCalendar.astro";
import SafeToggle from "../../../SafeToggle.astro";
import SafeWeek from "../../../SafeWeek.astro";
import SafeChat from "../../../SafeChat.astro";
import SafeTabs from "../../../SafeTabs.astro";
import SafeCallout from "../../../SafeCallout.astro";
import SafeDragDrop from "../../../SafeDragDrop.astro";
import SafeGrid from "../../../SafeGrid.astro";
import SafeInput from "../../../SafeInput.astro";
import SafeList from "../../../SafeList.astro";
import SafePicker from "../../../SafePicker.astro";
import SafeNav from "../../../SafeNav.astro";

const componentNames = Object.keys(SAMPLES).sort();
const variationsOf = (c: string) => Object.keys(SAMPLES[c]).sort();
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>safeframeworks — astro/5 viewer</title>
  <link id="safestyle-link" rel="stylesheet" href="/styles/vanilla/components.css" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: system-ui, sans-serif; color: #1a1a1a; }
    .viewer { display: flex; height: 100vh; }
    .sidebar { width: 220px; border-right: 1px solid #e5e7eb; padding: 12px; overflow-y: auto; flex-shrink: 0; }
    .section-label { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #6b7280; margin-bottom: 8px; }
    .style-btn, .comp-btn, .var-btn { display: block; width: 100%; text-align: left; padding: 4px 8px; font-size: 13px; border: none; border-radius: 4px; cursor: pointer; background: transparent; color: #1a1a1a; margin-bottom: 2px; }
    .var-btn { padding-left: 22px; }
    .var-btn.hidden { display: none; }
    .style-btn.active, .comp-btn.active, .var-btn.active { background: #3b82f6; color: white; }
    .style-btn:hover, .comp-btn:hover, .var-btn:hover { background: #f3f4f6; }
    .style-btn.active:hover, .comp-btn.active:hover, .var-btn.active:hover { background: #3b82f6; }
    .main { flex: 1; overflow-y: auto; padding: 24px; }
    h3 { font-size: 14px; font-weight: 600; margin-bottom: 16px; }
    .active-comp { font-weight: 400; color: #6b7280; }
    .component-card { border: 1px solid #e5e7eb; border-radius: 8px; overflow: hidden; margin-bottom: 16px; }
    .component-card.hidden { display: none; }
    .component-label { padding: 8px 12px; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #6b7280; border-bottom: 1px solid #e5e7eb; background: #fafafa; }
    .component-body { padding: 16px; }
  </style>
</head>
<body>
  <div class="viewer">
    <div class="sidebar">
      <div class="section-label">STYLE</div>
      <button class="style-btn active" onclick="switchStyle('vanilla')">vanilla</button>
      <button class="style-btn" onclick="switchStyle('tailwind')">tailwind</button>
      <button class="style-btn" onclick="switchStyle('tailwind-daisy')">tailwind-daisy</button>
      <button class="style-btn" onclick="switchStyle('material')">material</button>

      <div class="section-label" style="margin-top:16px">COMPONENTS</div>
      <button class="comp-btn active" onclick="filterComp(null)">All</button>
      {componentNames.map((name) => (
        <>
          <button class="comp-btn" data-comp-btn={name} onclick={`filterComp('${name}')`}>{name}</button>
          {variationsOf(name).map((v) => (
            <button class="var-btn hidden" data-var-btn={v} data-parent={name} onclick={`filterVar('${name}','${v}')`}>{v}</button>
          ))}
        </>
      ))}
    </div>
    <div class="main">
      <h3>astro/5 — <span id="style-name">vanilla</span><span id="comp-name" class="active-comp"></span></h3>
    {Object.keys(SAMPLES["layout"]).sort().map((v) => (
      <div class="component-card" data-comp="layout" data-var={v}>
        <div class="component-label">{v}</div>
        <div class="component-body">
          <SafeLayout config={SAMPLES["layout"][v]} />
        </div>
      </div>
    ))}
    {Object.keys(SAMPLES["columns"]).sort().map((v) => (
      <div class="component-card" data-comp="columns" data-var={v}>
        <div class="component-label">{v}</div>
        <div class="component-body">
          <SafeColumns config={SAMPLES["columns"][v]} />
        </div>
      </div>
    ))}
    {Object.keys(SAMPLES["card"]).sort().map((v) => (
      <div class="component-card" data-comp="card" data-var={v}>
        <div class="component-label">{v}</div>
        <div class="component-body">
          <SafeCard config={SAMPLES["card"][v]} />
        </div>
      </div>
    ))}
    {Object.keys(SAMPLES["button"]).sort().map((v) => (
      <div class="component-card" data-comp="button" data-var={v}>
        <div class="component-label">{v}</div>
        <div class="component-body">
          <SafeButton config={SAMPLES["button"][v]} />
        </div>
      </div>
    ))}
    {Object.keys(SAMPLES["table"]).sort().map((v) => (
      <div class="component-card" data-comp="table" data-var={v}>
        <div class="component-label">{v}</div>
        <div class="component-body">
          <SafeTable config={SAMPLES["table"][v]} />
        </div>
      </div>
    ))}
    {Object.keys(SAMPLES["tree"]).sort().map((v) => (
      <div class="component-card" data-comp="tree" data-var={v}>
        <div class="component-label">{v}</div>
        <div class="component-body">
          <SafeTree config={SAMPLES["tree"][v]} />
        </div>
      </div>
    ))}
    {Object.keys(SAMPLES["sheet"]).sort().map((v) => (
      <div class="component-card" data-comp="sheet" data-var={v}>
        <div class="component-label">{v}</div>
        <div class="component-body">
          <SafeSheet config={SAMPLES["sheet"][v]} />
        </div>
      </div>
    ))}
    {Object.keys(SAMPLES["chart"]).sort().map((v) => (
      <div class="component-card" data-comp="chart" data-var={v}>
        <div class="component-label">{v}</div>
        <div class="component-body">
          <SafeChart config={SAMPLES["chart"][v]} />
        </div>
      </div>
    ))}
    {Object.keys(SAMPLES["heatmap"]).sort().map((v) => (
      <div class="component-card" data-comp="heatmap" data-var={v}>
        <div class="component-label">{v}</div>
        <div class="component-body">
          <SafeHeatmap config={SAMPLES["heatmap"][v]} />
        </div>
      </div>
    ))}
    {Object.keys(SAMPLES["gauge"]).sort().map((v) => (
      <div class="component-card" data-comp="gauge" data-var={v}>
        <div class="component-label">{v}</div>
        <div class="component-body">
          <SafeGauge config={SAMPLES["gauge"][v]} />
        </div>
      </div>
    ))}
    {Object.keys(SAMPLES["funnel"]).sort().map((v) => (
      <div class="component-card" data-comp="funnel" data-var={v}>
        <div class="component-label">{v}</div>
        <div class="component-body">
          <SafeFunnel config={SAMPLES["funnel"][v]} />
        </div>
      </div>
    ))}
    {Object.keys(SAMPLES["sankey"]).sort().map((v) => (
      <div class="component-card" data-comp="sankey" data-var={v}>
        <div class="component-label">{v}</div>
        <div class="component-body">
          <SafeSankey config={SAMPLES["sankey"][v]} />
        </div>
      </div>
    ))}
    {Object.keys(SAMPLES["treemap"]).sort().map((v) => (
      <div class="component-card" data-comp="treemap" data-var={v}>
        <div class="component-label">{v}</div>
        <div class="component-body">
          <SafeTreemap config={SAMPLES["treemap"][v]} />
        </div>
      </div>
    ))}
    {Object.keys(SAMPLES["timeline"]).sort().map((v) => (
      <div class="component-card" data-comp="timeline" data-var={v}>
        <div class="component-label">{v}</div>
        <div class="component-body">
          <SafeTimeline config={SAMPLES["timeline"][v]} />
        </div>
      </div>
    ))}
    {Object.keys(SAMPLES["map"]).sort().map((v) => (
      <div class="component-card" data-comp="map" data-var={v}>
        <div class="component-label">{v}</div>
        <div class="component-body">
          <SafeMap config={SAMPLES["map"][v]} />
        </div>
      </div>
    ))}
    {Object.keys(SAMPLES["calendar"]).sort().map((v) => (
      <div class="component-card" data-comp="calendar" data-var={v}>
        <div class="component-label">{v}</div>
        <div class="component-body">
          <SafeCalendar config={SAMPLES["calendar"][v]} />
        </div>
      </div>
    ))}
    {Object.keys(SAMPLES["toggle"]).sort().map((v) => (
      <div class="component-card" data-comp="toggle" data-var={v}>
        <div class="component-label">{v}</div>
        <div class="component-body">
          <SafeToggle config={SAMPLES["toggle"][v]} />
        </div>
      </div>
    ))}
    {Object.keys(SAMPLES["week"]).sort().map((v) => (
      <div class="component-card" data-comp="week" data-var={v}>
        <div class="component-label">{v}</div>
        <div class="component-body">
          <SafeWeek config={SAMPLES["week"][v]} />
        </div>
      </div>
    ))}
    {Object.keys(SAMPLES["chat"]).sort().map((v) => (
      <div class="component-card" data-comp="chat" data-var={v}>
        <div class="component-label">{v}</div>
        <div class="component-body">
          <SafeChat config={SAMPLES["chat"][v]} />
        </div>
      </div>
    ))}
    {Object.keys(SAMPLES["tabs"]).sort().map((v) => (
      <div class="component-card" data-comp="tabs" data-var={v}>
        <div class="component-label">{v}</div>
        <div class="component-body">
          <SafeTabs config={SAMPLES["tabs"][v]} />
        </div>
      </div>
    ))}
    {Object.keys(SAMPLES["callout"]).sort().map((v) => (
      <div class="component-card" data-comp="callout" data-var={v}>
        <div class="component-label">{v}</div>
        <div class="component-body">
          <SafeCallout config={SAMPLES["callout"][v]} />
        </div>
      </div>
    ))}
    {Object.keys(SAMPLES["drag-drop"]).sort().map((v) => (
      <div class="component-card" data-comp="drag-drop" data-var={v}>
        <div class="component-label">{v}</div>
        <div class="component-body">
          <SafeDragDrop config={SAMPLES["drag-drop"][v]} />
        </div>
      </div>
    ))}
    {Object.keys(SAMPLES["grid"]).sort().map((v) => (
      <div class="component-card" data-comp="grid" data-var={v}>
        <div class="component-label">{v}</div>
        <div class="component-body">
          <SafeGrid config={SAMPLES["grid"][v]} />
        </div>
      </div>
    ))}
    {Object.keys(SAMPLES["input"]).sort().map((v) => (
      <div class="component-card" data-comp="input" data-var={v}>
        <div class="component-label">{v}</div>
        <div class="component-body">
          <SafeInput config={SAMPLES["input"][v]} />
        </div>
      </div>
    ))}
    {Object.keys(SAMPLES["list"]).sort().map((v) => (
      <div class="component-card" data-comp="list" data-var={v}>
        <div class="component-label">{v}</div>
        <div class="component-body">
          <SafeList config={SAMPLES["list"][v]} />
        </div>
      </div>
    ))}
    {Object.keys(SAMPLES["picker"]).sort().map((v) => (
      <div class="component-card" data-comp="picker" data-var={v}>
        <div class="component-label">{v}</div>
        <div class="component-body">
          <SafePicker config={SAMPLES["picker"][v]} />
        </div>
      </div>
    ))}
    {Object.keys(SAMPLES["nav"]).sort().map((v) => (
      <div class="component-card" data-comp="nav" data-var={v}>
        <div class="component-label">{v}</div>
        <div class="component-body">
          <SafeNav config={SAMPLES["nav"][v]} />
        </div>
      </div>
    ))}
    </div>
  </div>
  <script is:inline>
    function switchStyle(s) {
      document.getElementById("safestyle-link").href = "/styles/" + s + "/components.css";
      document.getElementById("style-name").textContent = s;
      document.querySelectorAll(".style-btn").forEach(b => b.classList.remove("active"));
      event.target.classList.add("active");
    }
    function filterComp(name) {
      document.querySelectorAll(".component-card").forEach(c => {
        c.classList.toggle("hidden", name !== null && c.dataset.comp !== name);
      });
      document.querySelectorAll(".comp-btn").forEach(b => b.classList.remove("active"));
      document.querySelectorAll(".var-btn").forEach(b => {
        b.classList.remove("active");
        b.classList.toggle("hidden", name === null || b.dataset.parent !== name);
      });
      if (event) event.target.classList.add("active");
      document.getElementById("comp-name").textContent = name ? " — " + name : "";
    }
    function filterVar(comp, v) {
      document.querySelectorAll(".component-card").forEach(c => {
        c.classList.toggle("hidden", !(c.dataset.comp === comp && c.dataset.var === v));
      });
      document.querySelectorAll(".comp-btn, .var-btn").forEach(b => b.classList.remove("active"));
      event.target.classList.add("active");
      document.getElementById("comp-name").textContent = " — " + v;
    }
  </script>
</body>
</html>
