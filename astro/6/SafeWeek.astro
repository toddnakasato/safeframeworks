---
/**
 * SafeWeek — Astro 6 weekly planner.
 * Renders via shared-mapping week builder (./week) — identical across
 * frameworks (figma Atom Week Specs). Server-renders the shell; client
 * script mounts the planner. Structure + data-* only.
 */
import type { ConfigBase, OnSafeEvent } from 'safecontracts';
interface Props { config: ConfigBase; onEvent?: OnSafeEvent; }
const { config } = Astro.props;
---

<div data-week-config={JSON.stringify(config)}></div>

<script>
  import { initSafeWeeks } from "./week";
  initSafeWeeks();
</script>
