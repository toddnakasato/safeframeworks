---
/**
 * SafeSheet — Astro 6 sheet component.
 * Renders via shared-mapping sheet builder (./sheet) — identical across
 * frameworks (HyperFormula calc engine). Server-renders the shell; client
 * script mounts the sheet. Structure + data-* only.
 */
import type { ConfigBase, OnSafeEvent } from 'safecontracts';
interface Props { config: ConfigBase; onEvent?: OnSafeEvent; }
const { config } = Astro.props;
---

<div data-sheet-config={JSON.stringify(config)}></div>

<script>
  import { initSafeSheets } from "./sheet";
  initSafeSheets();
</script>
