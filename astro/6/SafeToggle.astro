---
/**
 * SafeToggle — Astro 6 toggle component.
 * Renders via shared-mapping toggle builder (./toggle) — identical across
 * frameworks. Server-renders the shell; client script mounts the switch.
 * Structure + data-* only. No hardcoded CSS.
 */
import type { ConfigBase, OnSafeEvent } from 'safecontracts';
interface Props { config: ConfigBase; onEvent?: OnSafeEvent; }
const { config } = Astro.props;
---

<div data-toggle-config={JSON.stringify(config)}></div>

<script>
  import { initSafeToggles } from "./toggle";
  initSafeToggles();
</script>
