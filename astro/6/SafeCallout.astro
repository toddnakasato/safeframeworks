---
/**
 * SafeCallout — Astro 6 callout component.
 * Renders via shared-mapping callout builder (./callout) — identical across
 * frameworks. Server-renders the shell; client script mounts the callout.
 * Structure + data-* only.
 */
import type { ConfigBase, OnSafeEvent } from 'safecontracts';
interface Props { config: ConfigBase; onEvent?: OnSafeEvent; }
const { config } = Astro.props;
---

<div data-callout-config={JSON.stringify(config)}></div>

<script>
  import { initSafeCallouts } from "./callout";
  initSafeCallouts();
</script>
