---
/**
 * SafeTimeline — Astro 6 timeline component.
 * Renders via shared-mapping timeline builder (./timeline) — identical across
 * frameworks. Server-renders the shell; client script mounts the timeline.
 * Structure + data-* only.
 */
import type { ConfigBase, OnSafeEvent } from 'safecontracts';
interface Props { config: ConfigBase; onEvent?: OnSafeEvent; }
const { config } = Astro.props;
---

<div data-timeline-config={JSON.stringify(config)}></div>

<script>
  import { initSafeTimelines } from "./timeline";
  initSafeTimelines();
</script>
