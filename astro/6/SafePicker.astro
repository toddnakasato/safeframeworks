---
/**
 * SafePicker — Astro 6 searchable list/card picker.
 * Renders via shared-mapping picker builder (./picker) — identical across
 * frameworks. Server-renders the shell; client script mounts the component.
 * Structure + data-* only.
 */
import type { ConfigBase, OnSafeEvent } from 'safecontracts';
interface Props { config: ConfigBase; onEvent?: OnSafeEvent; }
const { config } = Astro.props;
---

<div data-picker-config={JSON.stringify(config)}></div>

<script>
  import { initSafePickers } from "./picker";
  initSafePickers();
</script>
