---
/**
 * SafeInput — Astro 6 input component.
 * Renders via shared-mapping input builder (./input) — identical across
 * frameworks. Server-renders the shell; client script mounts the field.
 * Structure + data-* only. No hardcoded CSS.
 */
import type { ConfigBase, OnSafeEvent } from 'safecontracts';
interface Props { config: ConfigBase; onEvent?: OnSafeEvent; }
const { config } = Astro.props;
---

<div data-input-config={JSON.stringify(config)}></div>

<script>
  import { initSafeInputs } from "./input";
  initSafeInputs();
</script>
