---
/**
 * SafeMap — Astro 6 map component.
 * Renders via shared-mapping map builder (./map) — identical across frameworks.
 * Server-renders the shell; a client script mounts Leaflet on the container.
 * Leaflet + OpenStreetMap. Outputs data-* attributes for intent. No hardcoded CSS.
 */
import type { ConfigBase, OnSafeEvent } from 'safecontracts';
interface Props { config: ConfigBase; onEvent?: OnSafeEvent; }
const { config } = Astro.props;
---

<div
  data-component="map"
  data-variant={config.metadata.variant}
>
  <div data-map-config={JSON.stringify(config)} data-map-container></div>
</div>

<script>
  import { initSafeMaps } from "./map";
  initSafeMaps();
</script>
