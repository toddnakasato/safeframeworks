---
/**
 * SafeButton — Astro 6 button component.
 * Renders via shared-mapping button builder (./button) — identical across
 * frameworks. Server-renders the shell; client script mounts the button.
 * Structure + data-* only.
 */
import type { ConfigBase, OnSafeEvent } from 'safecontracts';
interface Props { config: ConfigBase; onEvent?: OnSafeEvent; }
const { config } = Astro.props;
---

<div data-button-config={JSON.stringify(config)}></div>

<script>
  import { initSafeButtons } from "./button";
  initSafeButtons();
</script>
