---
/**
 * SafeGrid — Astro 6 grid component.
 * Renders via shared-mapping grid builder (./grid) — identical across
 * frameworks. Server-renders the shell; client script mounts the grid.
 * Structure + data-* only.
 */
import type { ConfigBase, OnSafeEvent } from 'safecontracts';
interface Props { config: ConfigBase; onEvent?: OnSafeEvent; }
const { config } = Astro.props;
---

<div data-grid-config={JSON.stringify(config)}></div>

<script>
  import { initSafeGrids } from "./grid";
  initSafeGrids();
</script>
