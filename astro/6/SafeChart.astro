---
/**
 * SafeChart — Astro 6 chart component.
 * Renders via Chart.js (same builder in every framework — identical rendering).
 * Server-renders the shell; a client script mounts Chart.js on the canvas.
 * Outputs data-* attributes for intent. No hardcoded CSS.
 */
import type { ConfigBase, OnSafeEvent } from 'safecontracts';
interface Props { config: ConfigBase; onEvent?: OnSafeEvent; }
const { config } = Astro.props;
---

<div
  data-component="chart"
  data-variant={config.metadata.variant}
  data-chart-type={config.metadata.chartType}
>
  <div data-role="title">{config.metadata.title || "Chart"}</div>
  <div data-role="chart-area" style="position:relative;height:240px">
    <canvas data-chart-config={JSON.stringify(config)}></canvas>
  </div>
</div>

<script>
  import { initSafeCharts } from "./chart";
  initSafeCharts();
</script>
