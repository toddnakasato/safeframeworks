---
/**
 * SafeCard — Astro 6 card component.
 * Implements card contract from safecontracts.
 * Outputs data-* attributes for intent. No hardcoded CSS.
 */
import type { ConfigBase, OnSafeEvent } from 'safecontracts';

interface Props {
  config: ConfigBase;
  onEvent?: OnSafeEvent;
}

const { config, onEvent } = Astro.props;
---

<div
  data-component="card"
  data-variant={config.metadata.variant}
  data-surface={config.metadata.surface}
  data-spacing={config.metadata.spacing}
  data-radius={config.metadata.radius}
  data-density={config.metadata.density}
>
  {config.metadata.header && <div data-role="header">{config.metadata.header}</div>}
  <slot />
</div>
