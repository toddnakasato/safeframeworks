---
import SafeLayout from "../../../SafeLayout.astro";
import SafeColumns from "../../../SafeColumns.astro";
import SafeCard from "../../../SafeCard.astro";
import SafeButton from "../../../SafeButton.astro";
import SafeTable from "../../../SafeTable.astro";
import SafeTree from "../../../SafeTree.astro";
import SafeSheet from "../../../SafeSheet.astro";
import SafeChart from "../../../SafeChart.astro";
import SafeHeatmap from "../../../SafeHeatmap.astro";
import SafeGauge from "../../../SafeGauge.astro";
import SafeFunnel from "../../../SafeFunnel.astro";
import SafeSankey from "../../../SafeSankey.astro";
import SafeTreemap from "../../../SafeTreemap.astro";
import SafeTimeline from "../../../SafeTimeline.astro";
import SafeMap from "../../../SafeMap.astro";
import SafeCalendar from "../../../SafeCalendar.astro";
import SafeToggle from "../../../SafeToggle.astro";
import SafeWeek from "../../../SafeWeek.astro";
import SafeChat from "../../../SafeChat.astro";
import SafeTabs from "../../../SafeTabs.astro";
import SafeCallout from "../../../SafeCallout.astro";
import SafeDragDrop from "../../../SafeDragDrop.astro";
import SafeGrid from "../../../SafeGrid.astro";
import SafeInput from "../../../SafeInput.astro";
import SafePicker from "../../../SafePicker.astro";
import SafeNav from "../../../SafeNav.astro";
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>safeframeworks — astro/6 viewer</title>
  <link id="safestyle-link" rel="stylesheet" href="/styles/vanilla/components.css" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: system-ui, sans-serif; color: #1a1a1a; }
    .viewer { display: flex; height: 100vh; }
    .sidebar { width: 220px; border-right: 1px solid #e5e7eb; padding: 12px; overflow-y: auto; flex-shrink: 0; }
    .section-label { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #6b7280; margin-bottom: 8px; }
    .style-btn, .comp-btn { display: block; width: 100%; text-align: left; padding: 4px 8px; font-size: 13px; border: none; border-radius: 4px; cursor: pointer; background: transparent; color: #1a1a1a; margin-bottom: 2px; }
    .style-btn.active, .comp-btn.active { background: #3b82f6; color: white; }
    .style-btn:hover, .comp-btn:hover { background: #f3f4f6; }
    .style-btn.active:hover, .comp-btn.active:hover { background: #3b82f6; }
    .main { flex: 1; overflow-y: auto; padding: 24px; }
    h3 { font-size: 14px; font-weight: 600; margin-bottom: 16px; }
    .active-comp { font-weight: 400; color: #6b7280; }
    .component-card { border: 1px solid #e5e7eb; border-radius: 8px; overflow: hidden; margin-bottom: 16px; }
    .component-card.hidden { display: none; }
    .component-label { padding: 8px 12px; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #6b7280; border-bottom: 1px solid #e5e7eb; background: #fafafa; }
    .component-body { padding: 16px; }
  </style>
</head>
<body>
  <div class="viewer">
    <div class="sidebar">
      <div class="section-label">STYLE</div>
      <button class="style-btn active" onclick="switchStyle('vanilla')">vanilla</button>
      <button class="style-btn" onclick="switchStyle('tailwind')">tailwind</button>
      <button class="style-btn" onclick="switchStyle('tailwind-daisy')">tailwind-daisy</button>
      <button class="style-btn" onclick="switchStyle('material')">material</button>

      <div class="section-label" style="margin-top:16px">COMPONENTS</div>
        <button class="comp-btn active" onclick="filterComp(null)">All</button>
        <button class="comp-btn" onclick="filterComp('layout')">layout</button>
        <button class="comp-btn" onclick="filterComp('columns')">columns</button>
        <button class="comp-btn" onclick="filterComp('card')">card</button>
        <button class="comp-btn" onclick="filterComp('button')">button</button>
        <button class="comp-btn" onclick="filterComp('table')">table</button>
        <button class="comp-btn" onclick="filterComp('tree')">tree</button>
        <button class="comp-btn" onclick="filterComp('sheet')">sheet</button>
        <button class="comp-btn" onclick="filterComp('chart')">chart</button>
        <button class="comp-btn" onclick="filterComp('heatmap')">heatmap</button>
        <button class="comp-btn" onclick="filterComp('gauge')">gauge</button>
        <button class="comp-btn" onclick="filterComp('funnel')">funnel</button>
        <button class="comp-btn" onclick="filterComp('sankey')">sankey</button>
        <button class="comp-btn" onclick="filterComp('treemap')">treemap</button>
        <button class="comp-btn" onclick="filterComp('timeline')">timeline</button>
        <button class="comp-btn" onclick="filterComp('map')">map</button>
        <button class="comp-btn" onclick="filterComp('calendar')">calendar</button>
        <button class="comp-btn" onclick="filterComp('toggle')">toggle</button>
        <button class="comp-btn" onclick="filterComp('week')">week</button>
        <button class="comp-btn" onclick="filterComp('chat')">chat</button>
        <button class="comp-btn" onclick="filterComp('tabs')">tabs</button>
        <button class="comp-btn" onclick="filterComp('callout')">callout</button>
        <button class="comp-btn" onclick="filterComp('drag-drop')">drag-drop</button>
        <button class="comp-btn" onclick="filterComp('grid')">grid</button>
        <button class="comp-btn" onclick="filterComp('input')">input</button>
        <button class="comp-btn" onclick="filterComp('picker')">picker</button>
        <button class="comp-btn" onclick="filterComp('nav')">nav</button>
    </div>
    <div class="main">
      <h3>astro/6 — <span id="style-name">vanilla</span><span id="comp-name" class="active-comp"></span></h3>
    <div class="component-card" data-comp="layout">
      <div class="component-label">layout</div>
      <div class="component-body">
        <SafeLayout config={{"component": "layout", "metadata": {"variant": "default"}}} />
      </div>
    </div>
    <div class="component-card" data-comp="columns">
      <div class="component-label">columns</div>
      <div class="component-body">
        <SafeColumns config={{"component": "columns", "metadata": {"spacing": "normal", "radius": "normal", "surface": "normal"}}} />
      </div>
    </div>
    <div class="component-card" data-comp="card">
      <div class="component-label">card</div>
      <div class="component-body">
        <SafeCard config={{"component": "card", "metadata": {"variant": "default", "surface": "normal", "spacing": "normal", "radius": "normal", "density": "normal", "title": "Sample Card", "subtitle": "Subtitle"}}} />
      </div>
    </div>
    <div class="component-card" data-comp="button">
      <div class="component-label">button</div>
      <div class="component-body">
        <SafeButton config={{"component": "button", "metadata": {"variant": "primary", "size": "md", "disabled": false, "loading": "normal", "fullWidth": "normal", "iconOnly": "normal", "selected": "normal", "status": "normal", "groupVariant": "normal", "groupDirection": "normal", "label": "Click Me"}}} />
      </div>
    </div>
    <div class="component-card" data-comp="table">
      <div class="component-label">table</div>
      <div class="component-body">
        <SafeTable config={{"component": "table", "metadata": {"variant": "default", "spacing": "normal", "headerStyle": "normal", "rowDivider": "normal", "rowNumbers": "normal", "truncate": "normal", "columnLines": "normal", "headerDivider": "normal", "zebra": "normal", "selectable": "normal"}}} />
      </div>
    </div>
    <div class="component-card" data-comp="tree">
      <div class="component-label">tree</div>
      <div class="component-body">
        <SafeTree config={{"component": "tree", "metadata": {"variant": "default", "spacing": "normal"}}} />
      </div>
    </div>
    <div class="component-card" data-comp="sheet">
      <div class="component-label">sheet</div>
      <div class="component-body">
        <SafeSheet config={{"component": "sheet", "metadata": {"variant": "default", "spacing": "normal", "surface": "normal"}}} />
      </div>
    </div>
    <div class="component-card" data-comp="chart">
      <div class="component-label">chart</div>
      <div class="component-body">
        <SafeChart config={{"component": "chart", "metadata": {"variant": "default", "chartType": "bar", "title": "Revenue"}}} />
      </div>
    </div>
    <div class="component-card" data-comp="heatmap">
      <div class="component-label">heatmap</div>
      <div class="component-body">
        <SafeHeatmap config={{"component": "heatmap", "metadata": {"variant": "default"}}} />
      </div>
    </div>
    <div class="component-card" data-comp="gauge">
      <div class="component-label">gauge</div>
      <div class="component-body">
        <SafeGauge config={{"component": "gauge", "metadata": {"variant": "default"}}} />
      </div>
    </div>
    <div class="component-card" data-comp="funnel">
      <div class="component-label">funnel</div>
      <div class="component-body">
        <SafeFunnel config={{"component": "funnel", "metadata": {"variant": "default"}}} />
      </div>
    </div>
    <div class="component-card" data-comp="sankey">
      <div class="component-label">sankey</div>
      <div class="component-body">
        <SafeSankey config={{"component": "sankey", "metadata": {"variant": "default"}}} />
      </div>
    </div>
    <div class="component-card" data-comp="treemap">
      <div class="component-label">treemap</div>
      <div class="component-body">
        <SafeTreemap config={{"component": "treemap", "metadata": {"variant": "default"}}} />
      </div>
    </div>
    <div class="component-card" data-comp="timeline">
      <div class="component-label">timeline</div>
      <div class="component-body">
        <SafeTimeline config={{"component": "timeline", "metadata": {"variant": "default"}}} />
      </div>
    </div>
    <div class="component-card" data-comp="map">
      <div class="component-label">map</div>
      <div class="component-body">
        <SafeMap config={{"component": "map", "metadata": {"variant": "default"}}} />
      </div>
    </div>
    <div class="component-card" data-comp="calendar">
      <div class="component-label">calendar</div>
      <div class="component-body">
        <SafeCalendar config={{"component": "calendar", "metadata": {"variant": "default", "size": "normal"}}} />
      </div>
    </div>
    <div class="component-card" data-comp="toggle">
      <div class="component-label">toggle</div>
      <div class="component-body">
        <SafeToggle config={{"component": "toggle", "metadata": {"variant": "default", "disabled": false, "labelPosition": "right", "label": "Enable feature", "checked": false}}} />
      </div>
    </div>
    <div class="component-card" data-comp="week">
      <div class="component-label">week</div>
      <div class="component-body">
        <SafeWeek config={{"component": "week", "metadata": {"variant": "default"}}} />
      </div>
    </div>
    <div class="component-card" data-comp="chat">
      <div class="component-label">chat</div>
      <div class="component-body">
        <SafeChat config={{"component": "chat", "metadata": {"title": "Chat", "placeholder": "Type a message..."}}} />
      </div>
    </div>
    <div class="component-card" data-comp="tabs">
      <div class="component-label">tabs</div>
      <div class="component-body">
        <SafeTabs config={{"component": "tabs", "metadata": {"variant": "default", "position": "top", "tabs": [{"key": "one", "label": "Tab One"}, {"key": "two", "label": "Tab Two"}]}}} />
      </div>
    </div>
    <div class="component-card" data-comp="callout">
      <div class="component-label">callout</div>
      <div class="component-body">
        <SafeCallout config={{"component": "callout", "metadata": {"variant": "info", "position": "top", "message": "This is a callout."}}} />
      </div>
    </div>
    <div class="component-card" data-comp="drag-drop">
      <div class="component-label">drag-drop</div>
      <div class="component-body">
        <SafeDragDrop config={{"component": "drag-drop", "metadata": {"variant": "default"}}} />
      </div>
    </div>
    <div class="component-card" data-comp="grid">
      <div class="component-label">grid</div>
      <div class="component-body">
        <SafeGrid config={{"component": "grid", "metadata": {"spacing": "normal", "radius": "normal", "surface": "normal", "collapsible": false}}} />
      </div>
    </div>
    <div class="component-card" data-comp="input">
      <div class="component-label">input</div>
      <div class="component-body">
        <SafeInput config={{"component": "input", "metadata": {"inputType": "text", "align": "normal", "valign": "normal", "placeholder": "Type here..."}}} />
      </div>
    </div>
    <div class="component-card" data-comp="picker">
      <div class="component-label">picker</div>
      <div class="component-body">
        <SafePicker config={{"component": "picker", "metadata": {"variant": "default"}}} />
      </div>
    </div>
    <div class="component-card" data-comp="nav">
      <div class="component-label">nav</div>
      <div class="component-body">
        <SafeNav config={{"component": "nav", "metadata": {"navStyle": "classic", "title": "Viewer"}}} />
      </div>
    </div>
    </div>
  </div>
  <script is:inline>
    function switchStyle(s) {
      document.getElementById("safestyle-link").href = "/styles/" + s + "/components.css";
      document.getElementById("style-name").textContent = s;
      document.querySelectorAll(".style-btn").forEach(b => b.classList.remove("active"));
      event.target.classList.add("active");
    }
    function filterComp(name) {
      document.querySelectorAll(".component-card").forEach(c => {
        c.classList.toggle("hidden", name !== null && c.dataset.comp !== name);
      });
      document.querySelectorAll(".comp-btn").forEach(b => b.classList.remove("active"));
      event.target.classList.add("active");
      document.getElementById("comp-name").textContent = name ? " — " + name : "";
    }
  </script>
</body>
</html>
