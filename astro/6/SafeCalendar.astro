---
/**
 * SafeCalendar — Astro 6 calendar component.
 * Renders via shared-mapping calendar builder (./calendar) — identical across
 * frameworks. Server-renders the shell; client script mounts the calendar.
 * Structure + data-* only.
 */
import type { ConfigBase, OnSafeEvent } from 'safecontracts';
interface Props { config: ConfigBase; onEvent?: OnSafeEvent; }
const { config } = Astro.props;
---

<div data-calendar-config={JSON.stringify(config)}></div>

<script>
  import { initSafeCalendars } from "./calendar";
  initSafeCalendars();
</script>
