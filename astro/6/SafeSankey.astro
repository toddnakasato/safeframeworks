---
/**
 * SafeSankey — Astro 6 sankey component.
 * Renders via shared-mapping sankey builder (./sankey) — identical across frameworks.
 * Server-renders the shell; a client script mounts the D3 sankey on the SVG.
 * Outputs data-* attributes for intent. No hardcoded CSS.
 */
import type { ConfigBase, OnSafeEvent } from 'safecontracts';
interface Props { config: ConfigBase; onEvent?: OnSafeEvent; }
const { config } = Astro.props;
---

<div
  data-component="sankey"
  data-variant={config.metadata.variant}
>
  {config.metadata.title && <div data-role="title">{config.metadata.title}</div>}
  <svg data-sankey-config={JSON.stringify(config)} data-sankey-svg></svg>
</div>

<script>
  import { initSafeSankeys } from "./sankey";
  initSafeSankeys();
</script>
